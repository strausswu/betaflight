# Target configuration for STM32F722 TOMATO CLOCK

TARGET = STM32F722_TOMATO
TARGET_MCU = STM32F722
TARGET_MCU_FAMILY = STM32F7

USE_PWM = 0
USE_DSHOT = 0
USE_ACC = 0
USE_GYRO = 0
USE_BARO = 0
USE_MAG = 0

USE_LED_STRIP = 1
USE_BEEPER = 1
USE_UART = 1
USE_SPI = 1

TARGET_FLASH_SIZE = 512
LD_SCRIPT = $(LINKER_DIR)/stm32_flash_f722.ld
STARTUP = startup_stm32f722xx
